<idea-plugin>
    <id>com.nit.release</id>
    <name>Nit</name>
    <version>9.7.0</version>
    <vendor>Trent</vendor>

    <description><![CDATA[
    Automated Release Management for your projects. Runs nit CLI directly from WebStorm
    with a dedicated tool window and actions.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Nit Release"
                    anchor="right"
                    secondary="false"
                    icon="AllIcons.Actions.Upload"
                    factoryClass="com.nit.release.toolwindow.NitToolWindowFactory"/>

        <applicationService
                serviceImplementation="com.nit.release.settings.NitSettings"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.nit.release.settings.NitConfigurable"
                id="com.nit.release.settings.NitConfigurable"
                displayName="Nit Release"/>
    </extensions>

    <actions>
        <group id="NitRelease.Menu" text="Nit" popup="true"
               icon="AllIcons.Actions.Upload">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <action id="NitRelease.Run"
                    class="com.nit.release.actions.NitReleaseAction"
                    text="Run Release"
                    description="Run a full nit release"
                    icon="AllIcons.Actions.Execute"/>


            <action id="NitRelease.Interactive"
                    class="com.nit.release.actions.NitInteractiveAction"
                    text="Interactive Release"
                    description="Run release in interactive mode"
                    icon="AllIcons.Actions.RunAll"/>
        </group>
    </actions>
</idea-plugin>

